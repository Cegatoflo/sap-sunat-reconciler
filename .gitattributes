# Normaliza fin de línea: el repo guarda LF; en checkout cada quien recibe lo suyo.
* text=auto eol=lf

# Windows-native: estos SÍ deben quedar en CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Linux-native: siempre LF (systemd/nginx no toleran CRLF)
*.service   text eol=lf
*.timer     text eol=lf
*.conf      text eol=lf
*.sh        text eol=lf

# Binarios: no tocar
*.png binary
*.jpg binary
*.ico binary

# Estadísticas de lenguaje de GitHub: no contar generados/vendored ni docs
package-lock.json      linguist-generated=true
*.tsbuildinfo          linguist-generated=true
frontend/dist/**       linguist-generated=true
*.md                   linguist-documentation=true
