# ============================================================
#  Plantilla de configuración. Copia este archivo a `.env` y
#  completa los valores reales.  EL .env NUNCA SE SUBE A GIT.
#
#      copy .env.example .env
# ============================================================

# ---------- Aplicación ----------
APP_ENV=development
# Clave para firmar cookies de sesión. Genera una nueva con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambiame-por-una-clave-larga-y-aleatoria
SESION_HORAS=12

# ---------- SAP: mismo servidor para todas las empresas ----------
SAP_BASE_URL=https://sap-server.local:50000/b1s/v1
# Verificación del certificado TLS del Service Layer.
#   true  = valida el certificado (PRODUCCIÓN — requiere instalar el CA interno)
#   false = lo ignora (solo desarrollo; inseguro, permite man-in-the-middle)
SAP_VERIFY_SSL=false
# Ruta a un CA bundle propio, si aplica (deja vacío para usar el del sistema)
SAP_CA_BUNDLE=

# ---------- Acceso: valores por defecto (cada empresa puede redefinirlos con su prefijo) ----------
DEPARTAMENTOS_PERMITIDOS=4
NOMBRE_DEPARTAMENTO=Contabilidad
MANAGERS_EXTRA=manager

# ---------- Correo (alertas de disconformidad) ----------
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=reportes@tuempresa.com
SMTP_FROM_NAME=Alertas SUNAT
# Destinatarios separados por coma
SMTP_TO=contabilidad@tuempresa.com,sistemas@tuempresa.com

# ---------- CORS (para el frontend de React en desarrollo) ----------
CORS_ORIGINS=http://localhost:18451

# ======================================================================
#  EMPRESAS (multi-tenant)
#
#  El usuario y clave que la persona escribe en el login son SIEMPRE de SAP;
#  lo único que cambia según la empresa elegida es el Company DB contra el
#  que se valida, y qué credenciales de SUNAT se usan para bajar la propuesta.
#
#  1) Lista los códigos en EMPRESAS (sin espacios, separados por coma).
#  2) Por cada código, define su bloque de variables con ese prefijo.
#  3) Una empresa incompleta NO tumba la app: solo falla, con mensaje claro,
#     cuando alguien intenta loguearse en ella. Ver backend/app/empresas.py.
# ======================================================================
EMPRESAS=EMPRESA1

# ---------- Ejemplo de una empresa (repetir el bloque por cada una, con su propio prefijo) ----------
EMPRESA1_NOMBRE=Mi Empresa S.A.C.
EMPRESA1_SAP_COMPANY_DB=SBO_MIEMPRESA_PROD
# Cuenta de servicio de SAP para ESE Company DB (lee facturas/proveedores/usuarios)
EMPRESA1_SAP_SERVICE_USER=manager
EMPRESA1_SAP_SERVICE_PASSWORD=
# Credenciales de la app SUNAT de esta empresa (portal "Registre su aplicación")
EMPRESA1_SUNAT_RUC=
EMPRESA1_SUNAT_CLIENT_ID=
EMPRESA1_SUNAT_CLIENT_SECRET=
# Usuario y clave SOL (formato usuario: RUC + usuarioSOL, ej. 20xxxxxxxxxUSUARIO)
EMPRESA1_SUNAT_SOL_USER=
EMPRESA1_SUNAT_SOL_PASSWORD=
# Opcionales — si no se definen, usan los valores globales de arriba
# EMPRESA1_DEPARTAMENTOS_PERMITIDOS=4
# EMPRESA1_NOMBRE_DEPARTAMENTO=Contabilidad
# EMPRESA1_MANAGERS_EXTRA=manager

# ---------- Para agregar una segunda empresa (multi-tenant): ----------
# EMPRESAS=EMPRESA1,EMPRESA2
# EMPRESA2_NOMBRE=Otra Empresa S.A.C.
# EMPRESA2_SAP_COMPANY_DB=SBO_OTRAEMPRESA_PROD
# EMPRESA2_SAP_SERVICE_USER=manager
# EMPRESA2_SAP_SERVICE_PASSWORD=
# EMPRESA2_SUNAT_RUC=
# EMPRESA2_SUNAT_CLIENT_ID=
# EMPRESA2_SUNAT_CLIENT_SECRET=
# EMPRESA2_SUNAT_SOL_USER=
# EMPRESA2_SUNAT_SOL_PASSWORD=
